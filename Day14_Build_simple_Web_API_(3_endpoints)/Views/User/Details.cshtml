@model WebAPI_Endpoint.Models.UserViewModel

@{
    ViewData["Title"] = "User Details Page";
}

<div class="container mt-5">
    <div class="card shadow" style="width: 25rem; margin: auto; border-radius: 15px; overflow: hidden;">
        <div class="card-header bg-primary text-white text-center">
            <h3>User Profile</h3>
        </div>
        <div class="card-body">
            
            <p><strong>ID:</strong> @Model.Id</p>
            <p><strong>Name:</strong> <span class="text-primary">@Model.Name</span></p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Status:</strong> 
                <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-danger")">
                    @Model.Status
                </span>
            </p>
        </div>
        <div class="card-footer text-center">
            <button class="btn btn-outline-primary btn-sm" onclick="alert('Bhai, View aise hi kaam karta hai!')">
                Click Me!
            </button>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .card:hover {
        transform: scale(1.02);
        transition: 0.3s;
    }
</style>
